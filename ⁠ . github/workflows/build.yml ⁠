name: Build GTA V ASI Mod

on:
  push:
    branches: [ "main" ]
  workflow_dispatch:

jobs:
  build:
    runs-on: windows-latest

    steps:
    - uses: actions/checkout@v4

    - name: Setup MSBuild
      uses: microsoft/setup-msbuild@v2

    - name: Download ScriptHookV SDK Stubs
      run: |
        # سحب ملفات مكتبة المطور ألكسندر بليد ليتم الدمج معها
        curl -L -o schook.zip https://github.com/scripthookv-gta5/ScriptHookV-SDK/archive/refs/heads/master.zip
        tar -xf schook.zip
        move ScriptHookV-SDK-master/inc/* .

    - name: Compile ASI File
      run: |
        # أمر المترجم لإنشاء ملف ديناميكي متوافق مع معمارية 64 بت للمحاكي
        cl.exe /LD /EHsc main.cpp /I. /Fe:WeaponsOnBack.asi /link /MACHINE:X64

    - name: Upload Finished Mod
      uses: actions/upload-artifact@v4
      with:
        name: GTA5-WeaponsOnBack-Mod
        path: WeaponsOnBack.asi
